{
  "name": "@tresdoce-nestjs-toolkit/root",
  "description": "Tresdoce NestJs Toolkit",
  "author": {
    "name": "Maximiliano \"Mex\" Delgado",
    "email": "mdelgado@tresdoce.com.ar",
    "url": "https://rudemex.github.io/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tresdoce/tresdoce-nestjs-toolkit.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tresdoce/tresdoce-nestjs-toolkit/issues"
  },
  "homepage": "https://github.com/tresdoce/tresdoce-nestjs-toolkit#readme",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "lint-staged",
    "prepublishOnly": "yarn build",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,md,json}\"",
    "version-packages": "lerna version --conventional-commits --force-git-tag --create-release github --yes",
    "publish:pkgs": "lerna publish from-git --no-verify-access --yes",
    "postinstall": "husky install && lerna bootstrap",
    "bs": "lerna bootstrap",
    "plop": "plop"
  },
  "workspaces": [
    "packages/*"
  ],
  "commitlint": {
    "extends": "@commitlint/config-conventional"
  },
  "prettier": {
    "semi": true,
    "tabWidth": 2,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "all"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,jsx,md,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/class-validator": "^0.13.4",
    "@nestjs/common": "^9.0.1",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "^9.0.1",
    "@nestjs/platform-express": "^9.0.1",
    "@nestjs/swagger": "^6.0.1",
    "@nestjs/terminus": "^8.1.1",
    "lodash": "4.17.21",   
    "reflect-metadata": "0.1.13",
    "rxjs": "7.5.5",
    "shx": "0.3.4",
    "testcontainers": "^8.11.0",
    "uuid": "8.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.18.6",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@commitlint/cli": "^17.0.3",
    "@commitlint/config-conventional": "^17.0.3",
    "@nestjs/cli": "^9.0.0",
    "@nestjs/schematics": "^9.0.1",
    "@nestjs/testing": "^9.0.1",
    "@pika/cli": "0.2.0",
    "@pika/pack": "0.5.0",
    "@pika/plugin-build-node": "0.9.2",
    "@pika/plugin-build-types": "0.9.2",
    "@pika/plugin-standard-pkg": "0.9.2",
    "@pika/plugin-ts-standard-pkg": "0.9.2",
    "@types/ejs": "3.1.1",
    "@types/express": "4.17.13",
    "@types/glob": "7.2.0",
    "@types/inline-css": "3.0.1",
    "@types/jest": "^28.1.4",
    "@types/node": "^18.0.3",
    "@types/nodemailer": "6.4.4",
    "@types/pug": "2.0.6",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.30.5",
    "@typescript-eslint/parser": "^5.30.5",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.1",
    "jest": "^28.1.2",
    "jest-extended": "^2.0.0",
    "jest-sonar-reporter": "2.0.0",
    "lerna": "^5.1.8",
    "lint-staged": "^13.0.3",
    "nodemailer-mock": "1.5.12",
    "plop": "^3.1.1",
    "prettier": "^2.7.1",
    "rimraf": "3.0.2",
    "supertest": "^6.2.4",
    "testcontainers": "^8.11.0",
    "ts-jest": "^28.0.5",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.8.2",
    "tsconfig-paths": "^4.0.0",
    "turbo": "^1.3.1",
    "typescript": "^4.7.4"
  }
}
